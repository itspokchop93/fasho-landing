{
  "functions": {
    "src/pages/api/marketing-manager/system-settings/playlists-refresh-stream.ts": {
      "maxDuration": 300
    },
    "src/pages/api/marketing-manager/system-settings/playlists-refresh-targeted.ts": {
      "maxDuration": 300
    },
    "src/pages/api/**/*.ts": {
      "maxDuration": 60
    }
  },
  "build": {
    "env": {
      "NODE_EXTRA_CA_CERTS": "./DigiCertGlobalRootG2.crt.pem"
    }
  },
  "env": {
    "NODE_EXTRA_CA_CERTS": "./DigiCertGlobalRootG2.crt.pem"
  },
  "headers": [
    {
      "source": "/iframe-communicator.html",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; frame-ancestors *"
        }
      ]
    }
  ]
} 